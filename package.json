{
  "name": "engram-mcp",
  "version": "1.0.0",
  "description": "MCP server for semantic search over Claude Code conversation history using local embeddings",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "save": "node dist/save_session.js",
    "serve": "node dist/mcp_server.js",
    "init-db": "node dist/init_db.js"
  },
  "keywords": [
